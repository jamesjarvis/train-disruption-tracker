<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template. Copy to com.bexside.disruption.plist and replace __PROJECT_DIR__ with the
  absolute path to this repo, e.g. /Users/you/development/train-disruption-tracker.
  The README's setup steps do this substitution for you.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bexside.disruption</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- Run once a day at 06:00. If the Mac is asleep at 06:00, launchd runs the
         missed job when it next wakes. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>6</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/run.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/run.log</string>
</dict>
</plist>
