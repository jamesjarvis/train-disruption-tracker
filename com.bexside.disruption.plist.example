<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template. Copy to com.bexside.disruption.plist and replace __PROJECT_DIR__ with the
  absolute path to this repo, e.g. /Users/you/development/train-disruption-tracker.
  The README's setup steps do this substitution for you.

  Realtime Trains credentials (actual cancellation/delay data) are read from
  secrets/rtt.json or the RTT_USERNAME/RTT_PASSWORD env vars; add an
  <EnvironmentVariables> dict here if you prefer the env-var route.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bexside.disruption</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- Run every 2 hours from 06:00 to 20:00. If the Mac is asleep at a fire
         time, launchd runs the missed job when it next wakes. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Hour</key><integer>6</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>14</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
        <dict><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
    </array>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/run.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/run.log</string>
</dict>
</plist>
